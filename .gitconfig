[user]
	name = Perri Lee
	email = perrilee0711@gmail.com

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	default = current
	autoSetupRemote = true

[core]
	editor = vim
	autocrlf = input

[color]
	ui = auto

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	last = log -1 HEAD --stat
	graph = log --graph --oneline --all --decorate
	unstage = reset HEAD --
	# Perri 一人公司常用
	wip = !git add -A && git commit -m "WIP"
	undo = reset --soft HEAD^
